# ──────────────────────────────────────────────────────────────────────────────
# ARCA - Módulo Facturación Electrónica AFIP/ARCA para Factusol
# Copie este archivo como .env y complete los valores
# ──────────────────────────────────────────────────────────────────────────────

# CUIT del emisor (sin guiones, 11 dígitos)
AFIP_CUIT=20123456789

# Entorno: "homo" = homologación/testing | "prod" = producción AFIP
AFIP_ENV=homo

# Ruta al certificado digital otorgado por AFIP (PEM)
AFIP_CERT=certs/cert.pem

# Ruta a la clave privada del certificado (PEM)
AFIP_KEY=certs/key.pem

# Servicio de padrón AFIP: "A13" (completo, recomendado) | "A4" (básico)
PADRON_SERVICE=A13

# ──────────────────────────────────────────────────────────────────────────────
# FACTUSOL
# ──────────────────────────────────────────────────────────────────────────────

# Ruta completa a la base de datos de Factusol (.accdb o .mdb)
# En red usar: \\servidor\compartido\FACTUSOL.accdb
FACTUSOL_MDB=C:\Factusol\Datos\FACTUSOL.accdb

# Driver ODBC para Microsoft Access (no modificar generalmente)
ODBC_DRIVER=Microsoft Access Driver (*.mdb, *.accdb)

# Intervalo de revisión en modo Online/Automático (segundos)
# Mínimo recomendado: 10
POLL_INTERVAL=10
