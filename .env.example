# === Configuración de la Empresa ===
# Ruta a la base de datos Factusol (.mdb o .accdb)
FACTUSOL_DB_PATH=C:\ruta\a\tu\base\de\datos\factusol.mdb

# CUIT de la empresa (sin guiones)
EMPRESA_CUIT=20123456789

# Razón social
EMPRESA_RAZON_SOCIAL=Mi Empresa S.A.

# AFIP SDK Access Token (obtener de https://app.afipsdk.com)
AFIP_ACCESS_TOKEN=tu_access_token_aqui

# Entorno AFIP: development o production
AFIP_ENVIRONMENT=development

# Ruta al certificado digital (.crt) para producción
AFIP_CERT_PATH=certs/certificado.crt

# Ruta a la clave privada (.key) para producción
AFIP_KEY_PATH=certs/clave.key

# === Configuración de la App ===
SECRET_KEY=cambiar-por-una-clave-segura-aleatoria
DATABASE_URL=sqlite:///./app_data.db
